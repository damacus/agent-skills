#!/usr/bin/env fish
# cookbook-helpers — Idempotent helpers for sous-chefs cookbook modernization
# Usage: cookbook-helpers <command> [options]
#
# Commands:
#   platforms          Show current (non-EOL) platforms for Chef cookbooks
#   check-platforms    Compare a cookbook's metadata.rb against current platforms
#   check-kitchen      Verify kitchen.yml, kitchen.dokken.yml and CI matrix are in sync
#   check-stale-refs   Detect stale helper and recipe references under test/
#   ci-logs            Fetch raw GitHub Actions job logs for failed or in-progress jobs
#   check-structure    Validate cookbook directory structure
#   generate-metadata  Output supports lines for metadata.rb
#   generate-dokken    Output kitchen.dokken.yml platform entries
#   report             Full report: platforms + structure + kitchen sync

set -g TODAY (date -u +%Y-%m-%d)
if set -q XDG_CACHE_HOME
    set -g CACHE_DIR "$XDG_CACHE_HOME/cookbook-helpers"
else
    set -g CACHE_DIR "$HOME/.cache/cookbook-helpers"
end
set -g CACHE_TTL 86400 # 24 hours in seconds

# --- Colour helpers (disabled when piped) ---
if isatty stdout
    set -g RED '\033[0;31m'
    set -g GREEN '\033[0;32m'
    set -g YELLOW '\033[0;33m'
    set -g BLUE '\033[0;34m'
    set -g BOLD '\033[1m'
    set -g RESET '\033[0m'
else
    set -g RED ''
    set -g GREEN ''
    set -g YELLOW ''
    set -g BLUE ''
    set -g BOLD ''
    set -g RESET ''
end

# --- Utility functions ---

function die
    echo -e "$RED""error:""$RESET"" $argv" >&2
    exit 1
end

function info
    echo -e "$BLUE""→""$RESET"" $argv"
end

function ok
    echo -e "$GREEN""✓""$RESET"" $argv"
end

function warn
    echo -e "$YELLOW""⚠""$RESET"" $argv"
end

function require_cmd
    for cmd in $argv
        if not type -q $cmd
            # If command not found, check if mise can provide it
            if type -q mise; and mise which $cmd >/dev/null 2>/dev/null
                continue
            end
            die "required command not found: $cmd"
        end
    end
end

function run_chef_cmd
    set -l cmd $argv
    if type -q $cmd[1]
        $cmd
        return $status
    end

    if type -q mise
        mise exec -- $cmd
        return $status
    end

    return 127
end

function cmd_setup_mise
    set -l cookbook_dir "."
    if set -q argv[1]; and test -n "$argv[1]"
        set cookbook_dir $argv[1]
    end

    set -l mise_toml "$cookbook_dir/.mise.toml"
    if test -f "$mise_toml"
        ok ".mise.toml already exists"
    else
        echo '[env]' > "$mise_toml"
        echo '_.path = "/opt/chef-workstation/bin"' >> "$mise_toml"
        ok "created .mise.toml with Chef Workstation path"
        if type -q mise
            info "running 'mise trust'"
            mise trust "$mise_toml" >/dev/null 2>/dev/null
        end
    end
end

function repo_from_run_url
    set -l url $argv[1]
    set -l match (string match -r 'github\.com/([^/]+/[^/]+)/actions/runs/[0-9]+' -- $url)
    if test (count $match) -ge 2
        echo $match[2]
    end
end

function run_id_from_input
    set -l value $argv[1]
    if string match -rq '^[0-9]+$' -- $value
        echo $value
        return 0
    end

    set -l match (string match -r 'actions/runs/([0-9]+)' -- $value)
    if test (count $match) -ge 2
        echo $match[2]
        return 0
    end

    return 1
end

function current_repo_name
    set -l repo_root (git rev-parse --show-toplevel 2>/dev/null)
    if test -n "$repo_root"
        basename "$repo_root"
        return 0
    end

    basename (pwd)
end

function default_repo
    echo "sous-chefs/"(current_repo_name)
end

# --- Cached API fetch ---

function fetch_eol
    set -l product $argv[1]
    set -l cache_file "$CACHE_DIR/$product.json"

    mkdir -p "$CACHE_DIR"

    # Use cache if fresh
    if test -f "$cache_file"
        set -l now (date +%s)
        set -l file_mtime
        if test (uname) = Darwin
            set file_mtime (stat -f %m "$cache_file")
        else
            set file_mtime (stat -c %Y "$cache_file")
        end
        set -l age (math $now - $file_mtime)
        if test $age -lt $CACHE_TTL
            cat "$cache_file"
            return
        end
    end

    set -l url "https://endoflife.date/api/$product.json"
    set -l data
    set data (curl -sf "$url")
    or die "failed to fetch $url"
    echo "$data" > "$cache_file"
    echo "$data"
end

# --- Platform definitions ---
# Maps: sous-chefs name → endoflife.date product, version extraction, kitchen name pattern

# Each platform entry: eol_product|metadata_name|min_cycle|kitchen_prefix|dokken_image_prefix|pid_one_command|version_format|lts_only
# version_format: "major" (e.g. 9) or "major.minor" (e.g. 24.04)
# lts_only: "yes" to filter to LTS releases only (Ubuntu), "no" otherwise
set -g PLATFORMS \
    "almalinux|almalinux|8|almalinux|dokken/almalinux|/usr/lib/systemd/systemd|major|no" \
    "amazon-linux|amazon|2023|amazonlinux|dokken/amazonlinux|/usr/lib/systemd/systemd|major|no" \
    "centos-stream|centos_stream|9|centos-stream|dokken/centos-stream|/usr/lib/systemd/systemd|major|no" \
    "debian|debian|12|debian|dokken/debian|/bin/systemd|major|no" \
    "fedora|fedora|0|fedora|dokken/fedora|/usr/lib/systemd/systemd|major|no" \
    "opensuse|opensuseleap|15|opensuse-leap|dokken/opensuse-leap|/usr/lib/systemd/systemd|major.minor|no" \
    "oracle-linux|oracle|8|oraclelinux|dokken/oraclelinux|/usr/lib/systemd/systemd|major|no" \
    "rhel|redhat|8|redhat|dokken/redhat|/usr/lib/systemd/systemd|major|no" \
    "rocky-linux|rocky|8|rockylinux|dokken/rockylinux|/usr/lib/systemd/systemd|major|no" \
    "ubuntu|ubuntu|20.04|ubuntu|dokken/ubuntu|/bin/systemd|major.minor|yes"

# --- Helper: parse platform entry fields ---

function parse_platform
    set -l entry $argv[1]
    set -l fields (string split '|' $entry)
    set -g _eol_product $fields[1]
    set -g _meta_name $fields[2]
    set -g _min_cycle $fields[3]
    set -g _kitchen_prefix $fields[4]
    set -g _dokken_prefix $fields[5]
    set -g _pid_one $fields[6]
    set -g _fmt $fields[7]
    set -g _lts_only $fields[8]
end

# --- Core: get active (non-EOL) platform versions ---

function get_active_versions
    set -l eol_product $argv[1]
    set -l min_cycle $argv[2]
    set -l version_format $argv[3]
    set -l lts_only no
    if set -q argv[4]
        set lts_only $argv[4]
    end

    set -l data (fetch_eol "$eol_product")

    echo "$data" | jq -r --arg today "$TODAY" --arg min "$min_cycle" --arg fmt "$version_format" --arg lts "$lts_only" '
    def to_num: split(".") | (.[0] | tonumber) * 10000 + ((.[1] // "0") | tonumber);
    [.[] |
      # Determine if EOL
      select(
        (.eol == false) or
        ((.eol | type) == "string" and (.eol > $today))
      ) |
      # LTS filter (when lts_only == "yes", only include LTS releases)
      select(
        if $lts == "yes" then
          (.lts == true) or ((.lts | type) == "string")
        else
          true
        end
      ) |
      # Filter by minimum cycle
      select(
        if $fmt == "major.minor" then
          (.cycle | to_num) >= ($min | to_num)
        else
          (.cycle | tonumber) >= ($min | tonumber)
        end
      ) |
      .cycle
    ] | sort_by(
      if $fmt == "major.minor" then
        . | to_num
      else
        . | tonumber
      end
    ) | .[]
  '
end

# --- Commands ---

function cmd_platforms
    require_cmd curl jq

    echo -e "$BOLD""Active (non-EOL) platforms for sous-chefs cookbooks""$RESET"
    echo -e "Source: endoflife.date | Date: $TODAY"
    echo ""

    printf "%-20s %-15s %s\n" PLATFORM VERSIONS "METADATA NAME"
    printf "%-20s %-15s %s\n" -------- -------- -------------

    for entry in $PLATFORMS
        parse_platform $entry
        set -l versions (get_active_versions "$_eol_product" "$_min_cycle" "$_fmt" "$_lts_only" 2>/dev/null)
        set -l version_str (string join ', ' $versions)
        printf "%-20s %-15s %s\n" "$_eol_product" "$version_str" "$_meta_name"
    end
end

function cmd_check_platforms
    require_cmd curl jq

    set -l cookbook_dir "."
    if set -q argv[1]; and test -n "$argv[1]"
        set cookbook_dir $argv[1]
    end
    set -l metadata "$cookbook_dir/metadata.rb"

    if not test -f "$metadata"
        die "metadata.rb not found in $cookbook_dir"
    end

    echo -e "$BOLD""Platform check: $metadata""$RESET"
    echo ""

    set -l exit_code 0

    for entry in $PLATFORMS
        parse_platform $entry

        # Get active versions from API
        set -l active (get_active_versions "$_eol_product" "$_min_cycle" "$_fmt" "$_lts_only" 2>/dev/null)

        # Check if platform is in metadata.rb
        if grep -q "supports '$_meta_name'" "$metadata" 2>/dev/null
            or grep -q "supports \"$_meta_name\"" "$metadata" 2>/dev/null

            # Platform is listed — check for EOL concerns
            set -l meta_line (grep "supports .*$_meta_name" "$metadata" | head -1)

            if test (count $active) -eq 0
                warn "$_meta_name — listed in metadata.rb but ALL versions are EOL"
                set exit_code 1
            else
                set -l version_list (string join ', ' $active)
                ok "$_meta_name — active versions: $version_list"
                if test -n "$meta_line"
                    echo "    metadata.rb: "(string trim $meta_line)
                end
            end
        else
            # Platform not listed — only mention if it has active versions and is in our default set
            set -l min_num (string replace -a '.' '' $_min_cycle)
            if test (count $active) -gt 0; and test "$min_num" -gt 0 2>/dev/null
                set -l version_list (string join ', ' $active)
                info "$_meta_name — not in metadata.rb (active versions: $version_list)"
            end
        end
    end

    return $exit_code
end

function extract_kitchen_platforms
    set -l file $argv[1]
    set -l platforms (yq -r '.platforms[].name' "$file" 2>/dev/null)
    if test (count $platforms) -gt 0
        printf '%s\n' $platforms | sort -u
    end
end

function extract_ci_platforms
    set -l file $argv[1]
    # Check all job matrices for os or platform keys
    set -l platforms (yq -r '.. | select(has("matrix")) | .matrix | (.os // .platform) | .[]' "$file" 2>/dev/null)
    
    if test (count $platforms) -gt 0
        printf '%s\n' $platforms | sort -u
    end
end

function cmd_check_kitchen
    require_cmd yq
    set -l cookbook_dir "."
    if set -q argv[1]; and test -n "$argv[1]"
        set cookbook_dir $argv[1]
    end
    set -l kitchen_yml "$cookbook_dir/kitchen.yml"
    set -l kitchen_dokken "$cookbook_dir/kitchen.dokken.yml"
    set -l ci_yml "$cookbook_dir/.github/workflows/ci.yml"

    echo -e "$BOLD""Kitchen sync check: $cookbook_dir""$RESET"
    echo ""

    set -l exit_code 0
    set -l kitchen_platforms
    set -l dokken_platforms

    if test -f "$kitchen_yml"
        set kitchen_platforms (extract_kitchen_platforms "$kitchen_yml")
        info "kitchen.yml platforms:"
        for p in $kitchen_platforms
            echo "    $p"
        end
    else
        warn "kitchen.yml not found"
    end

    echo ""

    if test -f "$kitchen_dokken"
        set dokken_platforms (extract_kitchen_platforms "$kitchen_dokken")
        info "kitchen.dokken.yml platforms:"
        for p in $dokken_platforms
            echo "    $p"
        end

        if test -f "$kitchen_yml"
            set -l only_kitchen
            set -l only_dokken

            for p in $kitchen_platforms
                if not contains -- $p $dokken_platforms
                    set -a only_kitchen $p
                end
            end
            for p in $dokken_platforms
                if not contains -- $p $kitchen_platforms
                    set -a only_dokken $p
                end
            end

            echo ""
            if test (count $only_kitchen) -gt 0
                warn "In kitchen.yml but NOT in kitchen.dokken.yml:"
                for p in $only_kitchen
                    echo "    $p"
                end
                set exit_code 1
            end
            if test (count $only_dokken) -gt 0
                warn "In kitchen.dokken.yml but NOT in kitchen.yml:"
                for p in $only_dokken
                    echo "    $p"
                end
                set exit_code 1
            end
            if test (count $only_kitchen) -eq 0; and test (count $only_dokken) -eq 0
                ok "kitchen.yml and kitchen.dokken.yml platforms are in sync"
            end
        end
    else
        warn "kitchen.dokken.yml not found"
    end

    echo ""

    if test -f "$ci_yml"
        info "CI workflow found: $ci_yml"
        set -l raw_ci_platforms (extract_ci_platforms "$ci_yml")
        set -l ci_platforms
        
        # Normalize and filter CI platforms
        for p in $raw_ci_platforms
            # Exclude runners
            if string match -rq 'ubuntu-latest|macos-latest|windows-latest' "$p"
                continue
            end
            
            # Normalize dots
            set -l norm (string replace -a '.' '' $p)
            set -a ci_platforms $norm
        end

        if test (count $ci_platforms) -gt 0
            echo "  CI platforms detected (normalized):"
            for p in $ci_platforms
                echo "    $p"
            end
        end

        if test (count $kitchen_platforms) -gt 0
            set -l normalized_kitchen (string replace -a '.' '' $kitchen_platforms | sort -u)
            set -l only_kitchen
            set -l only_ci

            for p in $normalized_kitchen
                if not contains -- $p $ci_platforms
                    set -a only_kitchen $p
                end
            end
            for p in $ci_platforms
                # Verify if it's a known platform prefix before flagging as "missing from kitchen"
                set -l is_known no
                for entry in $PLATFORMS
                    parse_platform $entry
                    if string match -q "$_kitchen_prefix*" $p
                        set is_known yes
                        break
                    end
                end

                if test "$is_known" = yes; and not contains -- $p $normalized_kitchen
                    set -a only_ci $p
                end
            end

            echo ""
            if test (count $only_kitchen) -gt 0
                warn "In kitchen.yml but NOT in CI matrix (normalized):"
                for p in $only_kitchen
                    echo "    $p"
                end
                set exit_code 1
            end
            if test (count $only_ci) -gt 0
                warn "In CI matrix but NOT in kitchen.yml (normalized):"
                for p in $only_ci
                    echo "    $p"
                end
                set exit_code 1
            end
            if test (count $only_kitchen) -eq 0; and test (count $only_ci) -eq 0
                ok "kitchen.yml and CI matrix platforms are in sync (normalized)"
            end
        end
    else
        info "No CI workflow found at $ci_yml"
    end

    return $exit_code
end

function cmd_check_docs
    set -l cookbook_dir "."
    if set -q argv[1]; and test -n "$argv[1]"
        set cookbook_dir $argv[1]
    end

    set -l cookbook_name (cookbook_name_for_dir "$cookbook_dir")
    echo -e "$BOLD""Documentation check: $cookbook_dir""$RESET"
    echo ""

    set -l exit_code 0
    if not test -d "$cookbook_dir/resources"
        info "no resources/ directory found"
        return 0
    end

    set -l docs_dir "$cookbook_dir/documentation"
    if not test -d "$docs_dir"
        warn "missing documentation/ directory"
        set exit_code 1
    end

    for rbfile in (find "$cookbook_dir/resources" -maxdepth 1 -name '*.rb' 2>/dev/null)
        set -l bname (basename "$rbfile" .rb)
        # Skip partials
        if string match -q '_*' $bname
            continue
        end

        set -l doc_file "$docs_dir/"$cookbook_name"_$bname.md"
        if test -f "$doc_file"
            ok "documentation found: "(basename "$doc_file")
        else
            warn "missing documentation for resource $bname: "(basename "$doc_file")
            set exit_code 1
        end
    end

    return $exit_code
end

function cmd_check_structure
    set -l cookbook_dir "."
    if set -q argv[1]; and test -n "$argv[1]"
        set cookbook_dir $argv[1]
    end

    echo -e "$BOLD""Structure check: $cookbook_dir""$RESET"
    echo ""

    set -l exit_code 0

    # Required files
    set -l required_files metadata.rb Berksfile kitchen.yml kitchen.dokken.yml chefignore README.md

    for f in $required_files
        if test -f "$cookbook_dir/$f"
            ok "$f"
        else
            warn "missing: $f"
            set exit_code 1
        end
    end

    # Required directories
    set -l required_dirs resources spec test/integration test/cookbooks/test/recipes
    for d in $required_dirs
        if test -d "$cookbook_dir/$d"
            ok "$d/"
        else
            warn "missing: $d/"
            set exit_code 1
        end
    end

    echo ""

    # Directories that should NOT exist
    set -l banned_dirs recipes attributes
    for d in $banned_dirs
        if test -d "$cookbook_dir/$d"
            warn "should not exist: $d/ (custom resource cookbooks don't use $d)"
            set exit_code 1
        else
            ok "no $d/ directory (correct)"
        end
    end

    echo ""

    # Check for default test suite
    if test -d "$cookbook_dir/test/integration/default"
        ok "default integration test suite exists"
    else
        warn "missing: test/integration/default/ (every cookbook must have a default suite)"
        set exit_code 1
    end

    # Check frozen_string_literal in Ruby files
    set -l missing_frozen 0
    set -l rb_dirs
    for d in resources libraries spec
        if test -d "$cookbook_dir/$d"
            set -a rb_dirs "$cookbook_dir/$d"
        end
    end

    if test (count $rb_dirs) -gt 0
        for rbfile in (find $rb_dirs -name '*.rb' 2>/dev/null)
            if not head -1 "$rbfile" | grep -q 'frozen_string_literal: true'
                warn "missing frozen_string_literal: $rbfile"
                set missing_frozen 1
                set exit_code 1
            end
        end
    end

    if test $missing_frozen -eq 0
        ok "all Ruby files have frozen_string_literal: true"
    end

    # Check unified_mode and provides in resources
    set -l missing_unified 0
    set -l missing_provides 0
    if test -d "$cookbook_dir/resources"
        for rbfile in (find "$cookbook_dir/resources" -maxdepth 1 -name '*.rb' 2>/dev/null)
            set -l bname (basename "$rbfile")
            # Skip partials
            if string match -q '_*' $bname
                continue
            end
            if not grep -q 'unified_mode true' "$rbfile"
                warn "missing unified_mode true: $rbfile"
                set missing_unified 1
                set exit_code 1
            end
            if not grep -qE "provides :|provides '" "$rbfile"
                warn "missing provides :resource_name: $rbfile"
                set missing_provides 1
                set exit_code 1
            end
        end
    end

    if test $missing_unified -eq 0
        ok "all resources have unified_mode true"
    end
    if test $missing_provides -eq 0
        ok "all resources have provides declaration"
    end

    return $exit_code
end

function cookbook_name_for_dir
    set -l cookbook_dir $argv[1]
    set -l metadata "$cookbook_dir/metadata.rb"

    if test -f "$metadata"
        set -l detected_name (sed -nE "s/^name[[:space:]]+['\"]([^'\"]+)['\"].*/\1/p" "$metadata" | head -1)
        if test -n "$detected_name"
            echo "$detected_name"
            return 0
        end
    end

    basename "$cookbook_dir"
end

function collect_deleted_method_names
    set -l cookbook_dir $argv[1]

    if not git -C "$cookbook_dir" rev-parse --show-toplevel >/dev/null 2>/dev/null
        return 0
    end

    git -C "$cookbook_dir" diff --no-color --unified=0 -- . \
        | grep -E '^-([[:space:]]*)def[[:space:]]+[A-Za-z_][A-Za-z0-9_!?=]*' \
        | sed -E 's/^-([[:space:]]*)def[[:space:]]+([A-Za-z_][A-Za-z0-9_!?=]*).*/\2/' \
        | sort -u
end

function recipe_path_for_reference
    set -l cookbook_dir $argv[1]
    set -l cookbook_name $argv[2]
    set -l recipe_ref $argv[3]

    set -l parts (string split '::' "$recipe_ref")
    set -l namespace $parts[1]
    set -l recipe_name default
    if test (count $parts) -gt 1
        set recipe_name $parts[2]
    end

    if test "$namespace" = test
        echo "$cookbook_dir/test/cookbooks/test/recipes/$recipe_name.rb"
        return 0
    end

    if test "$namespace" = "$cookbook_name"
        echo "$cookbook_dir/recipes/$recipe_name.rb"
        return 0
    end

    if test (count $parts) -eq 1
        echo "$cookbook_dir/recipes/$namespace.rb"
        return 0
    end

    return 1
end

function cmd_check_stale_refs
    require_cmd git rg sed

    set -l cookbook_dir "."
    set -l explicit_methods
    if set -q argv[1]; and test -n "$argv[1]"
        set cookbook_dir $argv[1]
    end
    if test (count $argv) -gt 1
        set explicit_methods $argv[2..-1]
    end

    set -l test_dir "$cookbook_dir/test"
    if not test -d "$test_dir"
        die "test/ not found in $cookbook_dir"
    end

    set -l cookbook_name (cookbook_name_for_dir "$cookbook_dir")
    set -l deleted_methods (collect_deleted_method_names "$cookbook_dir")
    set -l method_names $explicit_methods $deleted_methods
    if test (count $method_names) -gt 0
        set method_names (printf '%s\n' $method_names | sort -u)
    end

    echo -e "$BOLD""Stale reference check: $cookbook_dir""$RESET"
    echo ""
    info "cookbook name: $cookbook_name"

    set -l exit_code 0

    if test (count $method_names) -gt 0
        info "deleted helper methods detected:"
        for method_name in $method_names
            echo "    $method_name"
        end
        echo ""

        for method_name in $method_names
            set -l matches (rg -n --glob '*.rb' --glob '*.yml' --glob '*.yaml' --word-regexp --fixed-strings "$method_name" "$test_dir" 2>/dev/null)
            if test -n "$matches"
                warn "stale references to deleted helper '$method_name':"
                printf '%s\n' $matches | sed 's/^/    /'
                set exit_code 1
            end
        end
    else
        info "no deleted helper methods detected in git diff"
    end

    echo ""

    set -l include_matches (rg -n --glob '*.rb' "include_recipe ['\"][^'\"]+['\"]" "$cookbook_dir/test/cookbooks" 2>/dev/null)
    set -l stale_recipe_refs
    if test -n "$include_matches"
        for match_line in (printf '%s\n' $include_matches)
            set -l recipe_ref (printf '%s\n' "$match_line" | sed -E "s/^[^:]+:[0-9]+:.*include_recipe ['\"]([^'\"]+)['\"].*/\1/")
            set -l recipe_path (recipe_path_for_reference "$cookbook_dir" "$cookbook_name" "$recipe_ref")
            if test -n "$recipe_path"; and not test -f "$recipe_path"
                set -a stale_recipe_refs "$match_line -> missing $recipe_path"
            end
        end
    end

    if test (count $stale_recipe_refs) -gt 0
        warn "stale include_recipe references:"
        printf '%s\n' $stale_recipe_refs | sed 's/^/    /'
        set exit_code 1
    else
        ok "no stale include_recipe references found"
    end

    if test $exit_code -eq 0
        ok "no stale references found under test/"
    end

    return $exit_code
end

function cmd_generate_metadata
    require_cmd curl jq

    echo -e "$BOLD""# Generated supports lines for metadata.rb""$RESET"
    echo "# Source: endoflife.date | Date: $TODAY"
    echo ""

    for entry in $PLATFORMS
        parse_platform $entry

        set -l versions (get_active_versions "$_eol_product" "$_min_cycle" "$_fmt" "$_lts_only" 2>/dev/null)
        if test (count $versions) -eq 0
            continue
        end

        # Get minimum active version for the constraint
        set -l min_version $versions[1]

        if test "$_meta_name" = fedora
            echo "supports 'fedora'"
        else if test "$_fmt" = "major.minor"
            echo "supports '$_meta_name', '>= $min_version'"
        else
            echo "supports '$_meta_name', '>= $min_version.0'"
        end
    end
end

function cmd_generate_dokken
    require_cmd curl jq

    echo -e "$BOLD""# Generated kitchen.dokken.yml platform entries""$RESET"
    echo "# Source: endoflife.date | Date: $TODAY"
    echo ""
    echo "platforms:"

    for entry in $PLATFORMS
        parse_platform $entry

        set -l versions (get_active_versions "$_eol_product" "$_min_cycle" "$_fmt" "$_lts_only" 2>/dev/null)
        if test (count $versions) -eq 0
            continue
        end

        for ver in $versions
            set -l platform_name "$_kitchen_prefix-$ver"
            set -l image "$_dokken_prefix-$ver"
            echo "  - name: $platform_name"
            echo "    driver:"
            echo "      image: $image"
            echo "      pid_one_command: $_pid_one"
        end
    end
end

function cmd_report
    set -l cookbook_dir "."
    if set -q argv[1]; and test -n "$argv[1]"
        set cookbook_dir $argv[1]
    end

    if type -q mise; and not test -f "$cookbook_dir/.mise.toml"
        warn "mise detected but no .mise.toml found. Run 'cookbook-helpers setup-mise' to fix."
    end

    cmd_platforms
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    cmd_check_structure "$cookbook_dir"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    cmd_check_docs "$cookbook_dir"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    cmd_check_platforms "$cookbook_dir"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    cmd_check_kitchen "$cookbook_dir"
end

function cmd_ci_logs
    require_cmd gh jq

    if test (count $argv) -eq 0
        echo "Usage: cookbook-helpers ci-logs <run-url-or-id> [--repo owner/name] [--job <job-id-or-name>] [--all]"
        return 1
    end

    set -l run_arg ""
    set -l repo ""
    set -l job_selector ""
    set -l include_all no
    set -l i 1

    while test $i -le (count $argv)
        set -l arg $argv[$i]
        switch $arg
            case --repo
                set i (math $i + 1)
                test $i -le (count $argv); or die "--repo requires a value"
                set repo $argv[$i]
            case --job
                set i (math $i + 1)
                test $i -le (count $argv); or die "--job requires a value"
                set job_selector $argv[$i]
            case --all
                set include_all yes
            case --help -h help
                echo "Usage: cookbook-helpers ci-logs <run-url-or-id> [--repo owner/name] [--job <job-id-or-name>] [--all]"
                echo "Defaults to sous-chefs/<cwd repo> when --repo is omitted."
                return 0
            case '*'
                if test -z "$run_arg"
                    set run_arg $arg
                else
                    die "unexpected argument: $arg"
                end
        end
        set i (math $i + 1)
    end

    test -n "$run_arg"; or die "missing run URL or run ID"

    set -l run_id (run_id_from_input "$run_arg")
    or die "could not parse run ID from: $run_arg"

    if test -z "$repo"
        set repo (repo_from_run_url "$run_arg")
    end

    if test -z "$repo"
        set repo (default_repo)
    end

    test -n "$repo"; or die "could not determine repository; pass --repo owner/name"

    set -l jobs_json (gh api "repos/$repo/actions/runs/$run_id/jobs?per_page=100")
    or die "failed to fetch jobs for run $run_id in $repo"

    set -l jq_filter '.jobs'
    if test "$include_all" = no
        set jq_filter "$jq_filter | map(select(.conclusion == \"failure\" or .status == \"in_progress\"))"
    end

    if test -n "$job_selector"
        if string match -rq '^[0-9]+$' -- $job_selector
            set jq_filter "$jq_filter | map(select((.id | tostring) == \"$job_selector\"))"
        else
            set jq_filter "$jq_filter | map(select(.name == \"$job_selector\" or (.name | contains(\"$job_selector\"))))"
        end
    end

    set -l selected_jobs (echo "$jobs_json" | jq -c "$jq_filter | .[]")

    if test (count $selected_jobs) -eq 0
        echo "No matching jobs found for run $run_id in $repo." >&2
        echo "" >&2
        echo "Available jobs:" >&2
        echo "$jobs_json" | jq -r '.jobs[] | "  \(.id)\t\(.status)\t\(.conclusion // "-")\t\(.name)"' >&2
        return 1
    end

    for job_json in $selected_jobs
        set -l job_id (echo "$job_json" | jq -r '.id')
        set -l job_name (echo "$job_json" | jq -r '.name')
        set -l job_status (echo "$job_json" | jq -r '.status')
        set -l job_conclusion (echo "$job_json" | jq -r '.conclusion // "-"')

        echo "===== job $job_id :: $job_name ====="
        echo "status=$job_status conclusion=$job_conclusion"
        gh api "repos/$repo/actions/jobs/$job_id/logs"
        or die "failed to fetch logs for job $job_id"
        echo ""
    end
end

# --- Main ---

function usage
    echo "Usage: cookbook-helpers <command> [cookbook-dir]"
    echo ""
    echo "Commands:"
    echo "  platforms           Show current (non-EOL) platforms for Chef cookbooks"
    echo "  check-platforms     Compare a cookbook's metadata.rb against current platforms"
    echo "  check-kitchen       Verify kitchen.yml and kitchen.dokken.yml are in sync"
    echo "  check-stale-refs    Detect stale helper and recipe references under test/"
    echo "  ci-logs             Fetch raw GitHub Actions job logs for failed or active jobs"
    echo "  check-structure     Validate cookbook directory structure"
    echo "  check-docs          Verify resource documentation exists"
    echo "  generate-metadata   Output supports lines for metadata.rb"
    echo "  generate-dokken     Output kitchen.dokken.yml platform entries"
    echo "  setup-mise          Create .mise.toml with standard Chef paths"
    echo "  report              Full report: platforms + structure + kitchen sync"
    echo ""
    echo "Options:"
    echo "  [cookbook-dir]       Path to cookbook (default: current directory)"
    echo ""
    echo "Environment:"
    echo "  CACHE_DIR           Override cache directory (default: ~/.cache/cookbook-helpers)"
end

function main
    set -l cmd ""
    if set -q argv[1]
        set cmd $argv[1]
    end
    set -l rest
    if test (count $argv) -gt 1
        set rest $argv[2..-1]
    end

    switch "$cmd"
        case platforms
            cmd_platforms $rest
        case check-platforms
            cmd_check_platforms $rest
        case check-kitchen
            cmd_check_kitchen $rest
        case check-stale-refs
            cmd_check_stale_refs $rest
        case ci-logs
            cmd_ci_logs $rest
        case check-structure
            cmd_check_structure $rest
        case check-docs
            cmd_check_docs $rest
        case generate-metadata
            cmd_generate_metadata $rest
        case generate-dokken
            cmd_generate_dokken $rest
        case setup-mise
            cmd_setup_mise $rest
        case report
            cmd_report $rest
        case -h --help help
            usage
        case ''
            usage
            exit 1
        case '*'
            die "unknown command: $cmd (try 'cookbook-helpers help')"
    end
end

main $argv
